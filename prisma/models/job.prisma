model Job {
    id            BigInt   @id @default(autoincrement())
    title         String
    description   String
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    link          String
    company       String
    wheresApplied String
    applierId     BigInt
    applier       User     @relation(fields: [applierId], references: [id], onDelete: Cascade)

    @@map("job")
}
