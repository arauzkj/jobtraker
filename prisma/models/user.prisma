model User {
  id              BigInt    @id @default(autoincrement())
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  username        String?   @unique
  displayUsername String?
  sessions        Session[]
  accounts        Account[]
  jobs            Job[]

  @@unique([email])
  @@map("user")
}
